# Google Analytics 4 service account JSON (server-only). Used by /api/ga4/report
# and /api/ga4/service-account. Generate a service account key in Google Cloud
# Console, then paste the entire JSON file contents as a single-line string.
GA4_SA_KEY={"type":"service_account","client_email":"...","private_key":"..."}

# Anthropic API key (server-only). Used by /api/suggest-initiatives.
ANTHROPIC_API_KEY=

# Supabase Auth (public — safe to expose to the browser). Find these in your
# Supabase project: Settings > API. Used for email/password and Google sign-in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
